# ══════════════════════════════════════════
#   МАРВЕЛ БОТ — Шаблон настроек
#   Скопируй в .env и заполни своими ключами
# ══════════════════════════════════════════

# ── Telegram ───────────────────────────────────────────────────────────────────
# Получи у @BotFather
TELEGRAM_BOT_TOKEN=

# Твой Telegram ID (узнай у @userinfobot)
ALLOWED_TELEGRAM_USERS=

# ── OpenRouter (GPT-4o — AI-чат и парсинг) ────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── OpenAI (Whisper STT + TTS голос) ──────────────────────────────────────────
# https://platform.openai.com/api-keys
# Опционально: без этого ключа голосовые сообщения не работают
OPENAI_WHISPER_KEY=

# ── Perplexity (поиск в интернете) ────────────────────────────────────────────
# https://www.perplexity.ai/settings/api
# Опционально: без него поиск недоступен
PERPLEXITY_API_KEY=

# ── CoinGecko Pro (опционально) ───────────────────────────────────────────────
# https://www.coingecko.com/en/api
# Без ключа работает free tier (10k запросов/мес)
COINGECKO_API_KEY=

# ── CryptoPanic (крипто новости, опционально) ─────────────────────────────────
# https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# ── Настройки ─────────────────────────────────────────────────────────────────
TIMEZONE=Europe/Moscow

# База данных
DB_PATH=marvel.db

# Утренний дайджест (час и минута)
MORNING_HOUR=8
MORNING_MINUTE=0
